# Bittensor
WALLET_NAME=engram
WALLET_HOTKEY=miner2
SUBTENSOR_NETWORK=test
NETUID=450

# Embedding Model
USE_LOCAL_EMBEDDER=true
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Vector Store
VECTOR_STORE_BACKEND=faiss
FAISS_INDEX_PATH=./data/miner.index

# Miner
MINER_PORT=8091
EXTERNAL_IP=YOUR_PUBLIC_IP     # set to your server's public IP
MAX_VECTORS_PER_NODE=5000000

# Anti-spam
INGEST_STAKE_TAO=0.001

LOG_LEVEL=INFO
