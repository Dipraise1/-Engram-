# Bittensor
WALLET_NAME=engram
WALLET_HOTKEY=default
SUBTENSOR_NETWORK=test
NETUID=450

# Embedding Model
USE_LOCAL_EMBEDDER=true
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Validator
VALIDATOR_PORT=8092
GROUND_TRUTH_PATH=./data/ground_truth.jsonl
SCORING_ALPHA=0.50
SCORING_BETA=0.30
SCORING_GAMMA=0.20
CHALLENGE_INTERVAL=300

# Miner fallback for local dev (used when axon.ip=0.0.0.0)
MINER_PORT=8091
MINER_IP=127.0.0.1

LOG_LEVEL=INFO
